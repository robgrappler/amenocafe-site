<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ameno Café | Llevamos la experiencia a tu evento</title>
    <meta name="description" content="Una nueva etapa para Ameno Café está en camino. Llevamos una barra de café de especialidad a tus eventos privados, corporativos y celebraciones." />
    <meta property="og:title" content="Ameno Café | Llevamos la experiencia a tu evento" />
    <meta property="og:description" content="Una nueva etapa para Ameno Café está en camino. Llevamos una barra de café de especialidad a tus eventos privados, corporativos y celebraciones." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://amenocafe.com/assets/AMENOogimage.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://amenocafe.com/assets/AMENOogimage.jpg" />
    <link rel="canonical" href="https://amenocafe.com" />
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg-brand:   #E6E5E3;
        --cafe:       #2c1b18;
        --cafe-soft:  #4a3532;
        --dorado:     #d4a373;
        --border:     rgba(44, 27, 24, 0.12);
        --font-main:  'Georgia', serif;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-main);
        color: var(--cafe);
        min-height: 100vh;
        background-color: var(--bg-brand);
        position: relative;
        overflow-x: hidden;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
        mix-blend-mode: multiply;
        z-index: 9999;
      }

      body.is-booting .reveal,
      body.is-booting .logo-img,
      body.is-booting .tagline,
      body.is-booting .notify-form,
      body.is-booting .socials,
      body.is-booting .section-title,
      body.is-booting .section-sub,
      body.is-booting .card,
      body.is-booting .services-footer {
        opacity: 0;
        transform: translateY(20px);
      }

      body.is-ready .reveal,
      body.is-ready .logo-img,
      body.is-ready .tagline,
      body.is-ready .notify-form,
      body.is-ready .socials,
      body.is-ready .section-title,
      body.is-ready .section-sub,
      body.is-ready .card,
      body.is-ready .services-footer {
        transition:
          opacity 1200ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
          transform 1200ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms);
        opacity: 1;
        transform: translateY(0);
      }

      .logo-img-wrapper {
        display: inline-block;
        margin-bottom: 60px;
      }

      .logo-img {
        width: min(480px, 85vw);
        height: auto;
      }

      .reveal {
        opacity: 0;
        transform: translateY(15px);
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 100px 24px;
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
      }

      .proximamente {
        font-weight: 700;
        font-size: clamp(2rem, 5vw, 2.8rem);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cafe);
        margin-bottom: 12px;
      }

      .tagline {
        font-size: clamp(1.1rem, 2.2vw, 1.3rem);
        color: var(--cafe-soft);
        margin-bottom: 60px;
        line-height: 1.6;
        letter-spacing: 0.02em;
      }

      .notify-form {
        display: grid;
        grid-template-columns: 1fr auto;
        width: min(500px, 90vw);
        border: 1px solid var(--cafe);
        margin-bottom: 60px;
        background: transparent;
      }
      .notify-form input {
        border: none;
        background: transparent;
        padding: 20px;
        font-family: var(--font-main);
        font-size: 1rem;
        color: var(--cafe);
        outline: none;
      }
      .notify-form input::placeholder { color: rgba(44, 27, 24, 0.4); }
      .notify-form button {
        border: none;
        background: var(--cafe);
        color: var(--bg-brand);
        padding: 0 40px;
        font-family: var(--font-main);
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        cursor: pointer;
        transition: background 200ms ease, color 200ms ease;
      }
      .notify-form button:hover {
        background: var(--bg-brand);
        color: var(--cafe);
      }

      .notify-status {
        width: min(500px, 90vw);
        margin-bottom: 40px;
        padding: 20px;
        border: 1px solid var(--cafe);
        font-size: 0.95rem;
        text-align: left;
        opacity: 0;
      }
      .notify-status.is-visible { opacity: 1; }

      .socials {
        display: flex;
        gap: 40px;
        margin-top: 20px;
      }
      .socials a {
        transition: transform 200ms ease;
      }
      .socials a:hover { transform: translateY(-2px); }
      .socials svg { width: 24px; height: 24px; }

      .location {
        margin-top: 48px;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        opacity: 0.6;
      }

      .services {
        padding: 120px 24px;
        background-color: rgba(0, 0, 0, 0.02);
      }
      .services-inner { max-width: 900px; margin: 0 auto; text-align: center; }

      .section-title {
        font-weight: 700;
        font-size: clamp(1.8rem, 4vw, 2.2rem);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 20px;
      }

      .section-sub {
        font-size: 1.15rem;
        max-width: 500px;
        margin: 0 auto 80px;
        line-height: 1.6;
        opacity: 0.7;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 60px;
        text-align: left;
      }
      .card h3 {
        font-weight: 700;
        font-size: 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 16px;
        border-bottom: 2px solid var(--cafe);
        padding-bottom: 10px;
      }
      .card p {
        font-size: 1.05rem;
        line-height: 1.7;
        opacity: 0.8;
      }

      .site-footer {
        padding: 100px 24px;
        text-align: center;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        opacity: 0.5;
      }
      .site-footer a { text-decoration: underline; font-weight: 700; }

      @media (max-width: 700px) {
        .cards { grid-template-columns: 1fr; gap: 48px; }
        .notify-form { grid-template-columns: 1fr; }
        .notify-form button { padding: 20px; }
        .hero { padding: 60px 24px; }
      }
    </style>
  </head>
  <body class="is-booting">

    <section class="hero">
      <div class="logo-img-wrapper reveal" style="--reveal-delay: 100ms;">
        <img src="/assets/AMENOCAFE.png" alt="Ameno Café" class="logo-img" />
      </div>

      <h1 class="proximamente reveal" style="--reveal-delay: 300ms;">Próximamente</h1>
      
      <div class="ornament reveal" style="--reveal-delay: 450ms;">
        <div class="ornament-icon">
          <svg viewBox="0 0 20 14" fill="none">
            <ellipse cx="10" cy="7" rx="8" ry="5.5" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </div>
      </div>

      <p class="tagline reveal" style="--reveal-delay: 600ms;">Llevamos la experiencia del café de especialidad a tu evento.</p>

      <form class="notify-form reveal" style="--reveal-delay: 800ms;" name="captura-email" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="captura-email" />
        <input id="email" name="email" type="email" placeholder="TU CORREO ELECTRÓNICO" required />
        <button type="submit">Suscribirme</button>
      </form>

      <div class="notify-status" id="notify-status" role="status" aria-live="polite" hidden></div>

      <div class="socials reveal" style="--reveal-delay: 1000ms;">
        <a href="https://wa.me/5215578688247" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.12 1.527 5.845L.057 23.5l5.797-1.448A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.838 0-3.563-.5-5.055-1.37l-.361-.214-3.44.859.874-3.353-.235-.374A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        </a>
        <a href="https://www.instagram.com/_amenocafe/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>

      <div class="location reveal" style="--reveal-delay: 1200ms;">
        Con base en Minatitlán, Veracruz
      </div>
    </section>

    <section class="services">
      <div class="services-inner">
        <h2 class="section-title reveal" style="--reveal-delay: 200ms;">Nuestros Servicios</h2>
        <p class="section-sub reveal" style="--reveal-delay: 400ms;">Llevamos una barra de café de especialidad a tus momentos más importantes.</p>

        <div class="cards">
          <article class="card reveal" style="--reveal-delay: 600ms;">
            <h3>Eventos Privados</h3>
            <p>Servicio de café para bodas, celebraciones y reuniones sociales con una estética cuidada y profesional.</p>
          </article>

          <article class="card reveal" style="--reveal-delay: 750ms;">
            <h3>Corporativos</h3>
            <p>Barra de café elegante para conferencias, oficinas y activaciones empresariales.</p>
          </article>

          <article class="card reveal" style="--reveal-delay: 900ms;">
            <h3>Catering</h3>
            <p>Bebidas preparadas al momento con hospitalidad y detalle para complementar tu evento.</p>
          </article>

          <article class="card reveal" style="--reveal-delay: 1050ms;">
            <h3>Personalizado</h3>
            <p>Adaptamos nuestra propuesta al estilo y atmósfera de tu evento para una experiencia coherente.</p>
          </article>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <p>&copy; 2026 Ameno Café &nbsp;·&nbsp; Minatitlán, Veracruz</p>
      <p style="margin-top: 10px;">Diseño por <a href="https://nodoalfa.com" target="_blank" rel="noopener noreferrer">Nodo Alfa</a></p>
    </footer>

    <script>
      const form = document.querySelector('.notify-form');
      const status = document.getElementById('notify-status');
      const isLocalPreview = /^(localhost|127\.0\.0\.1|::1)$/.test(window.location.hostname) || window.location.protocol === 'file:';
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      window.addEventListener('load', () => {
        if (prefersReducedMotion) {
          document.body.classList.remove('is-booting');
          document.body.classList.add('is-ready');
          return;
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.body.classList.remove('is-booting');
            document.body.classList.add('is-ready');
          });
        });
      }, { once: true });

      function showStatus(state, title, message) {
        status.hidden = false;
        status.dataset.state = state;
        status.innerHTML = `<strong>${title}</strong>${message}`;
        status.classList.remove('is-visible');

        if (prefersReducedMotion) {
          status.classList.add('is-visible');
          return;
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            status.classList.add('is-visible');
          });
        });
      }

      if (form && status) {
        const emailInput = form.querySelector('input[type="email"]');
        const submitButton = form.querySelector('button[type="submit"]');
        const originalButtonText = submitButton ? submitButton.textContent : 'Notificarme';

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          if (!form.reportValidity()) {
            return;
          }

          if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = 'Enviando...';
          }

          if (isLocalPreview) {
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = originalButtonText;
            }

            showStatus(
              'preview',
              'Vista previa local.',
              'El formulario está conectado a Netlify. Para guardar envíos reales, pruébalo en el sitio publicado.'
            );
            return;
          }

          try {
            const formData = new FormData(form);
            const response = await fetch('/', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: new URLSearchParams(formData).toString(),
            });

            if (!response.ok) {
              throw new Error('Netlify form submission failed');
            }

            form.classList.add('is-complete');

            if (emailInput) {
              emailInput.readOnly = true;
            }

            if (submitButton) {
              submitButton.disabled = true;
              submitButton.textContent = 'Enviado';
            }

            showStatus(
              'success',
              'Gracias.',
              'Ya te agregamos a la lista. Te avisaremos por correo cuando Ameno Café esté listo.'
            );
          } catch (error) {
            showStatus(
              'error',
              'No se pudo enviar.',
              'Intenta otra vez o escríbenos por WhatsApp si prefieres.'
            );

            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = originalButtonText;
            }

            if (emailInput) {
              emailInput.focus();
            }
          }
        });
      }
    </script>

  </body>
</html>
