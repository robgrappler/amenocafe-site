<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ameno Café | Llevamos la experiencia a tu evento</title>
    <meta
      name="description"
      content="Una nueva etapa para Ameno Café está en camino. Llevamos una barra de café de especialidad a tus eventos privados, corporativos y celebraciones."
    />
    <meta
      property="og:title"
      content="Ameno Café | Llevamos la experiencia a tu evento"
    />
    <meta
      property="og:description"
      content="Una nueva etapa para Ameno Café está en camino. Llevamos una barra de café de especialidad a tus eventos privados, corporativos y celebraciones."
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      content="https://amenocafe.com/assets/AMENOogimage_simple.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image"
      content="https://amenocafe.com/assets/AMENOogimage_simple.png"
    />
    <link rel="canonical" href="https://amenocafe.com" />
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script
      src="https://c.webfontfree.com/c.js?f=Kairengu"
      type="text/javascript"></script>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg-brand: #f8f4ea; /* 1. Off-white background */
        --brand-charcoal: #232323; /* 2. True charcoal gray (Logo/Main Titles) */
        --brand-gray: #5d594a; /* 3. Secondary gray (Secondary text/Tagline) */
        --brand-teal: #79b7b1; /* 4. Accent teal */
        --brand-orange: #de744c; /* 5. Accent orange */

        --font-main: "Georgia", serif;
        --font-accent: "Kairengu", "Playfair Display", serif;
      }

      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
      }
      img {
        max-width: 100%;
        height: auto;
      }

      body {
        font-family: var(--font-main);
        color: var(--brand-charcoal);
        min-height: 100vh;
        background-color: var(--bg-brand);
        position: relative;
        overflow-x: hidden;
        width: 100%;
      }

      /* Transitions and Reveals */
      body.is-booting .reveal {
        opacity: 0;
        transform: translateY(25px);
      }
      body.is-ready .reveal {
        transition:
          opacity 1400ms cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
          transform 1400ms cubic-bezier(0.22, 1, 0.36, 1)
            var(--reveal-delay, 0ms);
        opacity: 1;
        transform: translateY(0);
      }

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 160px 24px;
        text-align: center;
        max-width: 900px;
        margin: 0 auto;
      }

      .logo-img-wrapper {
        display: inline-block;
        margin-bottom: 80px;
      }

      .logo-img {
        width: min(480px, 85vw);
        height: auto;
        filter: grayscale(1) brightness(0.15);
      }

      .proximamente {
        font-family: var(--font-main);
        font-weight: bold;
        font-size: clamp(2.2rem, 8vw, 3.4rem);
        letter-spacing: 0.03em;
        color: var(--brand-orange);
        margin-bottom: 24px;
        line-height: 1.1;
      }

      .tagline {
        font-size: clamp(1.2rem, 2.5vw, 1.5rem);
        color: var(--brand-gray);
        margin-bottom: 80px;
        line-height: 1.7;
        letter-spacing: 0.02em;
        max-width: 600px;
      }

      .notify-form {
        display: grid;
        grid-template-columns: 1fr auto;
        width: min(520px, 90vw);
        border: 1px solid var(--brand-charcoal);
        margin-bottom: 80px;
        background: transparent;
      }
      .notify-form input {
        border: none;
        background: transparent;
        padding: 24px;
        font-family: var(--font-main);
        font-size: 1rem;
        color: var(--brand-charcoal);
        outline: none;
      }
      .notify-form input::placeholder {
        color: rgba(93, 89, 74, 0.5);
      }
      .notify-form button {
        border: none;
        background: var(--brand-charcoal);
        color: var(--bg-brand);
        padding: 0 40px;
        font-family: var(--font-main);
        font-weight: bold;
        font-size: 0.9rem;
        letter-spacing: 0.12em;
        cursor: pointer;
        transition: background 300ms ease;
      }
      .notify-form button:hover {
        background: var(--brand-orange);
      }

      .socials {
        display: flex;
        justify-content: center;
        gap: 48px;
        margin-top: 32px;
      }
      .socials a {
        color: var(--brand-teal);
        transition:
          color 300ms ease,
          transform 300ms ease;
        display: inline-block;
      }
      .socials a:hover {
        color: var(--brand-orange);
        transform: translateY(-3px);
      }
      .socials svg {
        width: 26px;
        height: 26px;
        fill: currentColor;
      }

      .location {
        margin-top: 80px;
        font-family: var(--font-main);
        font-size: 0.85rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--brand-gray);
        opacity: 0.8;
      }

      .services {
        padding: 160px 24px;
        background-color: rgba(93, 89, 74, 0.04);
      }
      .services-inner {
        max-width: 1100px;
        margin: 0 auto;
        text-align: center;
      }

      .section-title {
        font-family: var(--font-main);
        font-weight: bold;
        font-size: clamp(2.2rem, 5vw, 2.8rem);
        letter-spacing: 0.02em;
        margin-bottom: 32px;
        color: var(--brand-charcoal);
      }

      .section-sub {
        font-size: 1.3rem;
        max-width: 650px;
        margin: 0 auto 100px;
        line-height: 1.7;
        color: var(--brand-gray);
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 100px 80px;
        text-align: left;
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 16px;
      }

      .card-icon {
        width: 36px;
        height: 36px;
        object-fit: contain;
        opacity: 0.9;
        flex-shrink: 0;
      }

      .card h3 {
        font-family: var(--font-main);
        font-weight: bold;
        font-size: 1.5rem;
        letter-spacing: 0.02em;
        color: var(--brand-charcoal);
      }

      .card-divider {
        height: 2px;
        width: 100%;
        background-color: var(--brand-orange);
        margin-bottom: 24px;
        opacity: 0.8;
      }

      .card p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: var(--brand-gray);
      }

      .site-footer {
        padding: 120px 24px;
        text-align: center;
        font-size: 0.9rem;
        letter-spacing: 0.12em;
        color: var(--brand-gray);
      }
      .site-footer .footer-cafe-accent {
        font-family: var(--font-accent);
        font-size: 0.7em;
        text-transform: uppercase;
        color: var(--brand-charcoal);
        letter-spacing: 0.05em;
      }
      .site-footer p {
        margin-bottom: 12px;
      }
      .site-footer .designer-credit {
        font-size: 0.75rem;
        opacity: 0.6;
        letter-spacing: 0.1em;
      }
      .site-footer a {
        text-decoration: none;
        color: inherit;
        font-weight: normal;
        transition: color 300ms ease;
      }
      .site-footer a:hover {
        color: var(--brand-teal);
      }

      @media (max-width: 850px) {
        .cards {
          grid-template-columns: 1fr;
          gap: 60px;
        }
        .hero {
          padding: 100px 24px 80px;
        }
        .services {
          padding: 100px 24px;
        }
        .notify-form {
          grid-template-columns: 1fr;
          gap: 0;
        }
        .notify-form input {
          border-bottom: 1px solid rgba(35, 35, 35, 0.1);
          padding: 20px;
        }
        .notify-form button {
          padding: 24px;
          font-size: 1rem;
        }
        .section-sub {
          margin-bottom: 60px;
          font-size: 1.15rem;
        }
        .proximamente {
          font-size: clamp(1.8rem, 10vw, 2.8rem);
        }
      }
    </style>
  </head>
  <body class="is-booting">
    <section class="hero">
      <div class="logo-img-wrapper reveal" style="--reveal-delay: 100ms;">
        <img src="/assets/logo-brand.png" alt="Ameno Café" class="logo-img" />
      </div>

      <h1 class="proximamente reveal" style="--reveal-delay: 300ms;">
        Próximamente
      </h1>

      <p class="tagline reveal" style="--reveal-delay: 500ms;">
        Llevamos la experiencia del café de especialidad a tu evento.
      </p>

      <form
        class="notify-form reveal"
        style="--reveal-delay: 700ms;"
        name="captura-email"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="captura-email" />
        <input
          id="email"
          name="email"
          type="email"
          placeholder="TU CORREO ELECTRÓNICO"
          required
        />
        <button type="submit">Cotizar Evento</button>
      </form>

      <div
        class="notify-status"
        id="notify-status"
        role="status"
        aria-live="polite"
        hidden
      >
      </div>

      <div class="socials reveal" style="--reveal-delay: 900ms;">
        <a
          href="https://wa.me/5215578688247"
          aria-label="WhatsApp"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
            ></path><path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.127.557 4.12 1.527 5.845L.057 23.5l5.797-1.448A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.838 0-3.563-.5-5.055-1.37l-.361-.214-3.44.859.874-3.353-.235-.374A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/_amenocafe/"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
            ></path></svg
          >
        </a>
      </div>

      <div class="location reveal" style="--reveal-delay: 1100ms;">
        Minatitlán y Coatzacoalcos, Veracruz
      </div>
    </section>

    <section class="services">
      <div class="services-inner">
        <h2 class="section-title reveal" style="--reveal-delay: 200ms;">
          Nuestros Servicios
        </h2>
        <p class="section-sub reveal" style="--reveal-delay: 400ms;">
          Experiencias que elevan tus momentos más importantes.
        </p>

        <div class="cards">
          <article class="card reveal" style="--reveal-delay: 600ms;">
            <div class="card-header">
              <img src="/assets/coffee-bean.png" alt="" class="card-icon" />
              <h3>Eventos Privados</h3>
            </div>
            <div class="card-divider"></div>
            <p>
              Servicio de café de especialidad para bodas, celebraciones y
              reuniones sociales con una estética minimalista.
            </p>
          </article>

          <article class="card reveal" style="--reveal-delay: 750ms;">
            <div class="card-header">
              <img src="/assets/coffee-bean.png" alt="" class="card-icon" />
              <h3>Corporativos</h3>
            </div>
            <div class="card-divider"></div>
            <p>
              Barra de café elegante para oficinas, conferencias y activaciones
              de marca empresariales.
            </p>
          </article>

          <article class="card reveal" style="--reveal-delay: 900ms;">
            <div class="card-header">
              <img src="/assets/coffee-bean.png" alt="" class="card-icon" />
              <h3>Catering</h3>
            </div>
            <div class="card-divider"></div>
            <p>
              Hospitalidad y detalle en cada taza preparada al momento para
              complementar tu evento.
            </p>
          </article>

          <article class="card reveal" style="--reveal-delay: 1050ms;">
            <div class="card-header">
              <img src="/assets/coffee-bean.png" alt="" class="card-icon" />
              <h3>Personalizado</h3>
            </div>
            <div class="card-divider"></div>
            <p>
              Adaptamos nuestra propuesta al estilo y atmósfera de tu evento
              para una experiencia única.
            </p>
          </article>
        </div>
      </div>
    </section>

    <footer class="site-footer reveal" style="--reveal-delay: 1200ms;">
      <p>
        ©2026, ameno <span class="footer-cafe-accent">CAFÉ</span>. Todos los
        derechos reservados.
      </p>
      <p class="designer-credit">
        Diseño por <a
          href="https://nodoalfa.com"
          target="_blank"
          rel="noopener noreferrer">Nodo Alfa</a
        >
      </p>
    </footer>

    <script>
      const form = document.querySelector(
        ".notify-form",
      ) as HTMLFormElement | null;
      const status = document.getElementById("notify-status");
      const isLocalPreview =
        /^(localhost|127\.0\.0\.1|::1)$/.test(window.location.hostname) ||
        window.location.protocol === "file:";
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      window.addEventListener(
        "load",
        () => {
          if (prefersReducedMotion) {
            document.body.classList.remove("is-booting");
            document.body.classList.add("is-ready");
            return;
          }

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              document.body.classList.remove("is-booting");
              document.body.classList.add("is-ready");
            });
          });
        },
        { once: true },
      );

      function showStatus(state: string, title: string, message: string) {
        if (!status) return;
        status.hidden = false;
        (status as HTMLElement).dataset.state = state;
        status.innerHTML = `<strong>${title}</strong>${message}`;
        status.classList.remove("is-visible");

        if (prefersReducedMotion) {
          status.classList.add("is-visible");
          return;
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (status) status.classList.add("is-visible");
          });
        });
      }

      if (form && status) {
        const emailInput = form.querySelector(
          'input[type="email"]',
        ) as HTMLInputElement | null;
        const submitButton = form.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement | null;
        const originalButtonText = submitButton
          ? submitButton.textContent
          : "Cotizar Evento";

        form.addEventListener("submit", async (event) => {
          event.preventDefault();

          if (!form.reportValidity()) {
            return;
          }

          if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = "Enviando...";
          }

          if (isLocalPreview) {
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = originalButtonText;
            }

            showStatus(
              "preview",
              "Vista previa local.",
              "El formulario está conectado a Netlify. Para guardar envíos reales, pruébalo en el sitio publicado.",
            );
            return;
          }

          try {
            const formData = new FormData(form);
            const response = await fetch("/", {
              method: "POST",
              headers: { "Content-Type": "application/x-www-form-urlencoded" },
              body: new URLSearchParams(formData as any).toString(),
            });

            if (!response.ok) {
              throw new Error("Netlify form submission failed");
            }

            form.classList.add("is-complete");

            if (emailInput) {
              emailInput.readOnly = true;
            }

            if (submitButton) {
              submitButton.disabled = true;
              submitButton.textContent = "Enviado";
            }

            showStatus(
              "success",
              "Gracias.",
              "Ya te agregamos a la lista. Te avisaremos por correo cuando Ameno Café esté listo.",
            );
          } catch (error) {
            showStatus(
              "error",
              "No se pudo enviar.",
              "Intenta otra vez o escríbenos por WhatsApp si prefieres.",
            );

            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = originalButtonText;
            }

            if (emailInput) {
              emailInput.focus();
            }
          }
        });
      }
    </script>
  </body>
</html>
